# Copy this file to .env and fill in your API keys
# Get free keys from the links below

# Cricket API — https://cricapi.com (free tier)
VITE_CRICKET_API_KEY=your_cricapi_key_here

# Weather API — https://openweathermap.org/api (free tier)
VITE_WEATHER_API_KEY=your_openweather_key_here

# Football API — https://www.api-football.com (free tier, 100 req/day)
VITE_FOOTBALL_API_KEY=your_apifootball_key_here
